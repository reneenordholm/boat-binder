<section class="space-y-5">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-normal text-cyan-700">Clients</p>
      <h1 class="mt-1 text-3xl font-black tracking-normal">Owners</h1>
    </div>
    <%= link_to "Add owner", new_owner_path, class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-bold text-white shadow-sm" %>
  </div>

  <div class="rounded-md border border-slate-200 bg-white p-3 shadow-sm">
    <%= form_with url: owners_path, method: :get do |form| %>
      <label class="flex min-h-11 items-center gap-3 rounded-md px-2 py-2">
        <%= form.check_box :include_inactive, { checked: @include_inactive, class: "h-5 w-5 rounded border-slate-300 text-cyan-700" }, "1", nil %>
        <span class="text-sm font-bold text-slate-700">Include inactive owners</span>
        <%= form.submit "Apply", class: "ml-auto rounded-md bg-slate-900 px-4 py-2 text-sm font-bold text-white" %>
      </label>
    <% end %>
  </div>

  <div class="grid gap-3 md:grid-cols-2">
    <% @accounts.each do |account| %>
      <% contact = account.primary_contact %>
      <%= link_to owner_path(account), class: "block rounded-md border border-slate-200 bg-white p-4 shadow-sm" do %>
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-xl font-black"><%= account.name %></h2>
            <p class="mt-1 text-sm text-slate-600"><%= contact&.email.presence || "No email" %> - <%= contact&.phone.presence || "No phone" %></p>
            <p class="mt-2 text-sm font-semibold text-slate-500"><%= pluralize(account.assets.vessels.count, "vessel") %></p>
          </div>
          <%= status_chip(account.status_label, tone: account.status_tone) %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
