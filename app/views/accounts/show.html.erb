<section class="space-y-6">
  <div class="rounded-md bg-slate-950 p-5 text-white shadow-sm md:p-7">
    <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-normal text-cyan-200">Owner</p>
        <h1 class="mt-2 text-4xl font-black tracking-normal"><%= @account.name %></h1>
        <% if @account.notes.present? %>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-200"><%= @account.notes %></p>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= status_chip(@account.status_label, tone: @account.status_tone) %>
        <% if can_manage_records? %>
          <%= link_to "Edit", edit_owner_path(@account), class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-500 px-5 py-3 text-base font-black text-slate-950 shadow-sm" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
    <section class="space-y-5">
      <div class="rounded-md border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-xl font-black">Boat Binder account access</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">Linked owner users can sign in and are preferred for transactional customer emails.</p>
          </div>
          <% if admin_user? %>
            <%= link_to "Invite owner user", new_admin_user_path, class: "inline-flex min-h-10 items-center justify-center rounded-md bg-cyan-700 px-4 py-2 text-sm font-bold text-white shadow-sm" %>
          <% end %>
        </div>

        <% if @owner_user_memberships.any? %>
          <div class="mt-4 space-y-3">
            <% @owner_user_memberships.each do |membership| %>
              <% user = membership.user %>
              <div class="rounded-md border border-slate-200 bg-slate-50 p-4">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="font-black text-slate-950"><%= user.name.presence || user.email_address %></p>
                    <p class="mt-1 text-sm text-slate-600"><%= user.email_address %></p>
                    <div class="mt-2 flex flex-wrap gap-2">
                      <%= status_chip(user.role.humanize, tone: :neutral) %>
                      <% if user.invitation_pending? %>
                        <%= status_chip("Invitation pending", tone: :warning) %>
                      <% else %>
                        <%= status_chip(user.active? ? "User active" : "User inactive", tone: user.active? ? :success : :warning) %>
                      <% end %>
                      <%= status_chip(membership.active? ? "Access active" : "Access inactive", tone: membership.active? ? :success : :warning) %>
                      <%= status_chip(membership.transactional_email_eligible? ? "Email recipient eligible" : "Not email eligible", tone: membership.transactional_email_eligible? ? :success : :neutral) %>
                    </div>
                  </div>
                  <% if admin_user? %>
                    <%= link_to "Manage user", edit_admin_user_path(user), class: "inline-flex min-h-10 items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-bold text-white" %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="mt-4 rounded-md border border-dashed border-slate-300 bg-slate-50 p-4">
            <p class="font-bold text-slate-800">No linked owner users yet.</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Invite an owner user to give this account authenticated Boat Binder access.</p>
          </div>
        <% end %>
      </div>

      <div class="rounded-md border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-black">Additional contact information</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">Use this for a contact who does not have Boat Binder access. Transactional emails are sent to linked active owner users when available.</p>
        <% if contact = @account.primary_contact %>
          <div class="mt-3 space-y-2 text-sm text-slate-600">
            <p><span class="font-semibold text-slate-800">Name:</span> <%= contact.name %></p>
            <p><span class="font-semibold text-slate-800">Email:</span> <%= contact.email.presence || "Not set" %></p>
            <p><span class="font-semibold text-slate-800">Phone:</span> <%= contact.phone.presence || "Not set" %></p>
          </div>
        <% else %>
          <p class="mt-3 text-sm text-slate-600">No additional contact information saved yet.</p>
        <% end %>
      </div>
    </section>

    <section class="space-y-3">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-xl font-black">Vessels</h2>
        <% if can_manage_records? %>
          <%= link_to "Add vessel", new_vessel_path, class: "rounded-md px-3 py-2 text-sm font-bold text-cyan-700" %>
        <% end %>
      </div>
      <div class="grid gap-3 md:grid-cols-2">
        <% @vessels.each do |vessel| %>
          <%= link_to vessel_path(vessel), class: "block rounded-md border border-slate-200 bg-white p-4 shadow-sm" do %>
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-black"><%= vessel.name %></p>
                <p class="mt-1 text-sm text-slate-600"><%= vessel.location_label %></p>
              </div>
              <%= status_chip(vessel.active? ? "Active" : "Inactive", tone: vessel.active? ? :success : :neutral) %>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>
</section>
