<%= field_error_messages(account) %>
<%= field_error_messages(contact) if contact&.errors&.any? %>

<%= form_with model: account, url: account.persisted? ? owner_path(account) : owners_path, class: "space-y-5" do |form| %>
  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-black">Owner</h2>
    <div>
      <%= form.label :name, "Owner name", class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_field :name, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div>
      <%= form.label :notes, class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_area :notes, rows: 4, class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <label class="flex min-h-12 items-center gap-3 rounded-md border border-slate-300 px-4 py-3">
      <%= form.check_box :active, class: "h-5 w-5 rounded border-slate-300 text-cyan-700" %>
      <span class="text-sm font-bold text-slate-700">Active owner</span>
    </label>
  </section>

  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-black">Primary contact</h2>
    <%= fields_for :contact, contact do |contact_form| %>
      <div>
        <%= contact_form.label :name, "Contact name", class: "text-sm font-semibold text-slate-700" %>
        <%= contact_form.text_field :name, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= contact_form.label :email, class: "text-sm font-semibold text-slate-700" %>
          <%= contact_form.email_field :email, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
        </div>
        <div>
          <%= contact_form.label :phone, class: "text-sm font-semibold text-slate-700" %>
          <%= contact_form.telephone_field :phone, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
        </div>
      </div>
    <% end %>
  </section>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
    <%= form.submit account.persisted? ? "Save owner" : "Add owner", class: "min-h-12 rounded-md bg-cyan-700 px-5 py-3 text-base font-black text-white shadow-sm" %>
    <%= link_to "Cancel", account.persisted? ? owner_path(account) : owners_path, class: "inline-flex min-h-12 items-center justify-center rounded-md px-5 py-3 text-base font-bold text-slate-700" %>
  </div>
<% end %>
