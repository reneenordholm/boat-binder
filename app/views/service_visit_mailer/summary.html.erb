<% follow_up_items = service_visit_follow_up_items(@service_visit) %>
<% follow_up_needed = @service_visit.follow_up_needed? %>
<% notes_preview = @service_visit.summary.presence || @service_visit.condition_notes.presence %>
<% total_checks = service_visit_total_check_count(@service_visit) %>

<div style="background: #F7F5F2; color: #0B1F35; font-family: Arial, sans-serif; padding: 24px;">
  <div style="margin: 0 auto; max-width: 640px;">
    <div style="background: #0B1F35; border-radius: 10px; color: #FFFFFF; padding: 24px;">
      <p style="color: #7DAAB3; font-size: 12px; font-weight: 700; letter-spacing: 0; margin: 0 0 10px; text-transform: uppercase;">Boat Binder</p>
      <h1 style="font-size: 28px; line-height: 1.2; margin: 0;"><%= @vessel.name %> Service Visit</h1>
      <p style="color: #D7E4E7; font-size: 15px; line-height: 1.6; margin: 12px 0 0;">
        <strong><%= short_date(@service_visit.visit_date, account: @account) %></strong><br>
        Performed by <%= user_display_name(@service_visit.performed_by_user) %>
      </p>
    </div>

    <div style="background: #FFFFFF; border: 1px solid #E7DED2; border-radius: 10px; margin-top: 18px; padding: 20px;">
      <h2 style="font-size: 18px; margin: 0 0 16px;">Visit summary</h2>
      <table style="border-collapse: collapse; width: 100%;">
        <tr>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0; vertical-align: top; width: 42%;"><strong>Follow-up status</strong></td>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0;"><%= follow_up_needed ? "Follow-up needed" : "No follow-up needed" %></td>
        </tr>
        <tr>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0; vertical-align: top;"><strong>Engine summary</strong></td>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0;"><%= service_visit_email_engine_hour_summary(@service_visit) %></td>
        </tr>
        <tr>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0; vertical-align: top;"><strong>Report filed</strong></td>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0;"><%= local_datetime(@service_visit.created_at, account: @account) %></td>
        </tr>
        <tr>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0; vertical-align: top;"><strong>Inspection</strong></td>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0;">
            <% if total_checks.positive? %>
              <%= service_visit_checked_count(@service_visit) %> of <%= total_checks %> complete
            <% else %>
              Not recorded
            <% end %>
          </td>
        </tr>
        <tr>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0; vertical-align: top;"><strong>Battery checks</strong></td>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0;"><%= service_visit_battery_check_count(@service_visit) %> completed</td>
        </tr>
        <tr>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0 0; vertical-align: top;"><strong>Photos</strong></td>
          <td style="border-top: 1px solid #E7DED2; padding: 12px 0 0;"><%= pluralize(service_visit_photo_count(@service_visit), "photo") %></td>
        </tr>
      </table>
    </div>

    <div style="background: #FFFFFF; border: 1px solid #E7DED2; border-radius: 10px; margin-top: 18px; padding: 20px;">
      <h2 style="font-size: 18px; margin: 0 0 10px;">Notes preview</h2>
      <p style="color: #334155; font-size: 15px; line-height: 1.7; margin: 0;"><%= notes_preview.presence || "No notes recorded." %></p>
    </div>

    <div style="background: #FFFFFF; border: 1px solid #E7DED2; border-radius: 10px; margin-top: 18px; padding: 20px;">
      <h2 style="font-size: 18px; margin: 0 0 10px;">Follow-up items</h2>
      <% if follow_up_items.any? %>
        <ul style="color: #334155; font-size: 15px; line-height: 1.7; margin: 0; padding-left: 20px;">
          <% follow_up_items.each do |item| %>
            <li><%= item %></li>
          <% end %>
        </ul>
      <% elsif follow_up_needed %>
        <p style="color: #334155; font-size: 15px; line-height: 1.7; margin: 0;">Follow-up was marked during this visit.</p>
      <% else %>
        <p style="color: #334155; font-size: 15px; line-height: 1.7; margin: 0;">No follow-up items noted.</p>
      <% end %>
    </div>

    <p style="margin: 24px 0 0; text-align: center;">
      <%= link_to "View full report in Boat Binder",
          @report_url,
          style: "display: inline-block; border-radius: 8px; background: #1E5A7A; color: #FFFFFF; font-size: 15px; font-weight: 700; padding: 14px 18px; text-decoration: none;" %>
    </p>
  </div>
</div>
