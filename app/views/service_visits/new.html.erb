<section class="mx-auto max-w-3xl space-y-5">
  <div>
    <%= link_to "Back to #{@vessel.name}", vessel_path(@vessel), class: "inline-flex min-h-10 items-center rounded-md py-2 text-sm font-bold text-cyan-700" %>
    <p class="mt-3 text-sm font-bold uppercase tracking-normal text-cyan-700">Start visit</p>
    <h1 class="mt-1 text-3xl font-black tracking-normal"><%= @vessel.name %></h1>
    <p class="mt-2 text-sm text-slate-600"><%= [@vessel.marina, @vessel.slip.presence && "Slip #{@vessel.slip}"].compact.join(" - ") %></p>
  </div>

  <%= field_error_messages(@service_visit) %>

  <%= form_with model: @service_visit, url: vessel_service_visits_path(@vessel), class: "space-y-5" do |form| %>
    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-black">Visit details</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :visit_date, class: "text-sm font-semibold text-slate-700" %>
          <%= form.date_field :visit_date, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Captain</label>
          <div class="mt-2 flex min-h-12 items-center rounded-md border border-slate-200 bg-slate-50 px-4 py-3 text-base font-bold text-slate-700"><%= Current.user.email %></div>
        </div>
      </div>
      <div>
        <%= form.label :location, class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_field :location, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    </section>

    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-black">Engine hours</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        <% @service_visit.ordered_engine_readings.each do |reading| %>
          <div>
            <%= label_tag "service_visit_engine_#{reading.asset_engine_id}", "#{reading.display_name} Hours", class: "text-sm font-semibold text-slate-700" %>
            <%= number_field_tag "service_visit[engine_readings][#{reading.asset_engine_id}][hours]", reading.hours, id: "service_visit_engine_#{reading.asset_engine_id}", step: "0.1", inputmode: "decimal", placeholder: "124.5", class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-black">Inspection checklist</h2>
      <div class="space-y-3">
        <% @service_visit.ordered_inspection_checks.each_with_index do |check, index| %>
          <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
            <label class="flex min-h-12 items-center gap-3">
              <%= hidden_field_tag "service_visit[inspection_checks][#{index}][checked]", "0" %>
              <%= check_box_tag "service_visit[inspection_checks][#{index}][checked]", "1", check.checked?, class: "h-6 w-6 rounded border-slate-300 text-cyan-700" %>
              <span class="text-base font-black text-slate-800"><%= check.label %></span>
            </label>
            <%= text_field_tag "service_visit[inspection_checks][#{index}][notes]", check.notes, placeholder: "Optional note for #{check.label.downcase}", class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-base" %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg font-black">Battery checks</h2>
        <%= link_to "Add battery", new_vessel_battery_path(@vessel), class: "rounded-md px-3 py-2 text-sm font-bold text-cyan-700" %>
      </div>
      <% if @service_visit.service_visit_battery_checks.any? %>
        <div class="space-y-3">
          <% @service_visit.ordered_battery_checks.each do |battery_check| %>
            <% battery = battery_check.asset_battery %>
            <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
              <label class="flex min-h-12 items-start gap-3">
                <%= hidden_field_tag "service_visit[battery_checks][#{battery.id}][checked]", "0" %>
                <%= check_box_tag "service_visit[battery_checks][#{battery.id}][checked]", "1", battery_check.checked?, class: "mt-1 h-6 w-6 rounded border-slate-300 text-cyan-700" %>
                <span>
                  <span class="block text-base font-black text-slate-800"><%= battery.name %></span>
                  <span class="mt-1 block text-sm text-slate-600"><%= battery.location.presence || "Location not set" %></span>
                </span>
              </label>
              <div class="mt-2 grid gap-3 sm:grid-cols-[10rem_1fr]">
                <%= number_field_tag "service_visit[battery_checks][#{battery.id}][voltage]", battery_check.voltage, step: "0.01", inputmode: "decimal", placeholder: "12.70", class: "min-h-12 w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-base" %>
                <%= text_field_tag "service_visit[battery_checks][#{battery.id}][notes]", battery_check.notes, placeholder: "Optional battery note", class: "min-h-12 w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-base" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-md border border-amber-200 bg-amber-50 p-4">
          <p class="font-black text-amber-900">No batteries have been added for this vessel yet.</p>
          <p class="mt-1 text-sm leading-6 text-amber-800">Add batteries from the vessel detail page so they appear during future visits.</p>
        </div>
      <% end %>
    </section>

    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-black">Summary</h2>
      <div>
        <%= form.label :summary, "Owner summary", class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_area :summary, rows: 4, placeholder: "Short client-ready summary of today's check.", class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :condition_notes, "General condition notes", class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_area :condition_notes, rows: 4, placeholder: "Anything beyond the structured checklist.", class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    </section>

    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-black">Issues and follow-up</h2>
      <div>
        <label for="issue_title" class="text-sm font-semibold text-slate-700">Issue title</label>
        <input type="text" name="issue_title" id="issue_title" placeholder="Optional issue found" class="mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base">
      </div>
      <div>
        <label for="issue_body" class="text-sm font-semibold text-slate-700">Issue details</label>
        <textarea name="issue_body" id="issue_body" rows="4" placeholder="Describe the issue and what should happen next." class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base"></textarea>
      </div>
      <label class="flex min-h-12 items-center gap-3 rounded-md border border-slate-300 px-4 py-3">
        <%= form.check_box :follow_up_needed, class: "h-5 w-5 rounded border-slate-300 text-cyan-700" %>
        <span class="text-sm font-bold text-slate-700">Follow-up needed</span>
      </label>
      <div>
        <%= form.label :follow_up_notes, class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_area :follow_up_notes, rows: 4, placeholder: "Recommendations, parts, vendor, timing.", class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    </section>

    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-black">Photos</h2>
      <%= form.file_field :photos, multiple: true, accept: "image/*", capture: "environment", class: "block min-h-12 w-full rounded-md border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-base file:mr-3 file:rounded-md file:border-0 file:bg-cyan-700 file:px-4 file:py-2 file:font-bold file:text-white" %>
    </section>

    <div class="sticky bottom-16 z-20 -mx-4 bg-slate-50/95 px-4 py-3 backdrop-blur md:static md:mx-0 md:bg-transparent md:px-0">
      <%= form.submit "Save visit report", class: "min-h-14 w-full rounded-md bg-cyan-700 px-5 py-4 text-base font-black text-white shadow-lg md:shadow-sm", data: { turbo_submits_with: "Saving..." } %>
    </div>
  <% end %>
</section>
