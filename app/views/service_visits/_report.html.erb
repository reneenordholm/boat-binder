<% issue_notes = local_assigns.fetch(:issue_notes, []) %>
<% show_photos = local_assigns.fetch(:show_photos, true) %>
<% follow_up_notes = service_visit.follow_up_notes.to_s.strip %>
<% follow_up_items_present = follow_up_notes.present? %>

<article class="overflow-hidden rounded-md border border-[#E7DED2] bg-white shadow-sm shadow-[#0B1F35]/5">
  <header class="bg-[#0B1F35] p-5 text-white md:p-8">
    <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="text-sm font-black uppercase tracking-normal text-[#7DAAB3]">Client-ready service report</p>
        <h1 class="mt-2 text-3xl font-black tracking-normal"><%= vessel.name %> Visit Report</h1>
        <p class="mt-2 text-sm leading-6 text-slate-200">
          <%= short_date(service_visit.visit_date, account: vessel.account) %> by <%= user_display_name(service_visit.performed_by_user) %>
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= status_chip(follow_up_items_present ? "Follow-up needed" : "No follow-up", tone: follow_up_items_present ? :urgent : :success) %>
      </div>
    </div>
  </header>

  <div class="space-y-6 p-5 md:p-8">
    <section class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
      <div class="rounded-md bg-[#F7F5F2] p-4">
        <p class="text-sm font-semibold text-slate-500">Vessel</p>
        <p class="mt-1 font-black"><%= vessel.name %></p>
      </div>
      <div class="rounded-md bg-[#F7F5F2] p-4">
        <p class="text-sm font-semibold text-slate-500">Owner</p>
        <p class="mt-1 font-black"><%= vessel.owner_name %></p>
      </div>
      <div class="rounded-md bg-[#F7F5F2] p-4">
        <p class="text-sm font-semibold text-slate-500">Location</p>
        <p class="mt-1 font-black"><%= service_visit.location.presence || vessel.location_label %></p>
      </div>
      <div class="rounded-md bg-[#F7F5F2] p-4">
        <p class="text-sm font-semibold text-slate-500">Captain</p>
        <p class="mt-1 font-black"><%= user_display_name(service_visit.performed_by_user) %></p>
      </div>
      <div class="rounded-md bg-[#F7F5F2] p-4">
        <p class="text-sm font-semibold text-slate-500">Report filed</p>
        <p class="mt-1 font-black"><%= local_datetime(service_visit.created_at, account: vessel.account) %></p>
      </div>
    </section>

    <section class="grid gap-3 md:grid-cols-3">
      <div class="rounded-md border border-[#E7DED2] p-4">
        <p class="text-sm font-semibold text-slate-500">Engine hours</p>
        <p class="mt-2 text-lg font-black"><%= service_visit_engine_hour_summary(service_visit) %></p>
      </div>
      <div class="rounded-md border border-[#E7DED2] p-4">
        <p class="text-sm font-semibold text-slate-500">Inspection checks</p>
        <p class="mt-2 text-lg font-black">
          <% if service_visit_total_check_count(service_visit).positive? %>
            <%= service_visit_checked_count(service_visit) %> of <%= service_visit_total_check_count(service_visit) %> complete
          <% else %>
            Not recorded
          <% end %>
        </p>
      </div>
      <div class="rounded-md border border-[#E7DED2] p-4">
        <p class="text-sm font-semibold text-slate-500">Battery checks</p>
        <p class="mt-2 text-lg font-black"><%= service_visit_battery_check_count(service_visit) %> completed</p>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-black">Summary</h2>
      <div class="rounded-md border border-[#E7DED2] bg-[#F7F5F2] p-4">
        <p class="leading-7 text-slate-700"><%= service_visit.summary.presence || "No summary recorded." %></p>
      </div>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-black">Engine readings</h2>
      <% if service_visit.service_visit_engine_readings.any? %>
        <div class="grid gap-3 sm:grid-cols-2">
          <% service_visit.ordered_engine_readings.each do |reading| %>
            <div class="rounded-md border border-[#E7DED2] bg-white p-4">
              <p class="text-sm font-semibold text-slate-500"><%= reading.display_name %></p>
              <p class="mt-1 text-2xl font-black"><%= reading.hours.present? ? number_with_precision(reading.hours, precision: 1, strip_insignificant_zeros: true) : "Not recorded" %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-md border border-[#E7DED2] bg-white p-4">
          <p class="text-sm font-semibold text-slate-500">Engine hours</p>
          <p class="mt-1 text-2xl font-black"><%= service_visit.engine_hours.presence || "Not recorded" %></p>
        </div>
      <% end %>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-black">Inspection checklist</h2>
      <% if service_visit.service_visit_inspection_checks.any? %>
        <div class="grid gap-3 md:grid-cols-2">
          <% service_visit.ordered_inspection_checks.each do |check| %>
            <div class="rounded-md border <%= check.checked? ? "border-emerald-200 bg-emerald-50" : "border-slate-200 bg-slate-50" %> p-4">
              <div class="flex items-start justify-between gap-3">
                <p class="font-black"><%= check.label %></p>
                <%= status_chip(check.checked? ? "Checked" : "Not checked", tone: check.checked? ? :success : :neutral) %>
              </div>
              <% if check.notes.present? %>
                <p class="mt-2 text-sm leading-6 text-slate-700"><%= check.notes %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="leading-7 text-slate-700"><%= service_visit.condition_notes.presence || "No inspection checklist recorded." %></p>
      <% end %>
    </section>

    <% if service_visit.condition_notes.present? && service_visit.service_visit_inspection_checks.any? %>
      <section class="space-y-3">
        <h2 class="text-xl font-black">General condition notes</h2>
        <div class="rounded-md border border-[#E7DED2] bg-white p-4">
          <p class="leading-7 text-slate-700"><%= service_visit.condition_notes %></p>
        </div>
      </section>
    <% end %>

    <section class="space-y-3">
      <h2 class="text-xl font-black">Battery checks</h2>
      <% if service_visit.service_visit_battery_checks.any? %>
        <div class="grid gap-3 md:grid-cols-2">
          <% service_visit.ordered_battery_checks.each do |battery_check| %>
            <% battery = battery_check.asset_battery %>
            <div class="rounded-md border <%= battery_check.checked? ? "border-emerald-200 bg-emerald-50" : "border-slate-200 bg-slate-50" %> p-4">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="font-black"><%= battery.name %></p>
                  <p class="mt-1 text-sm text-slate-600"><%= battery.location.presence || "Location not set" %></p>
                </div>
                <%= status_chip(battery_check.checked? ? "Checked" : "Not checked", tone: battery_check.checked? ? :success : :neutral) %>
              </div>
              <div class="mt-3 space-y-2 text-sm text-slate-700">
                <p><span class="font-semibold">Voltage:</span> <%= battery_check.voltage.present? ? "#{number_with_precision(battery_check.voltage, precision: 2, strip_insignificant_zeros: true)} V" : "Not recorded" %></p>
                <% if battery_check.notes.present? %>
                  <p class="leading-6"><%= battery_check.notes %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="leading-7 text-slate-700">No battery checks were recorded for this visit.</p>
      <% end %>
    </section>

    <section class="space-y-3">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-xl font-black">Follow-up items</h2>
        <% if follow_up_items_present %>
          <%= status_chip("Action needed", tone: :urgent) %>
        <% end %>
      </div>
      <div class="rounded-md border <%= follow_up_items_present ? "border-amber-100 bg-amber-50" : "border-emerald-100 bg-emerald-50" %> p-4">
        <p class="leading-7 text-slate-700"><%= follow_up_items_present ? follow_up_notes : "No follow-up items noted." %></p>
      </div>
    </section>

    <% if issue_notes.any? %>
      <section class="space-y-3">
        <h2 class="text-xl font-black">Recent vessel issue notes</h2>
        <div class="space-y-3">
          <% issue_notes.each do |note| %>
            <div class="rounded-md border border-red-100 bg-red-50 p-4">
              <p class="font-bold text-red-900"><%= note.title %></p>
              <p class="mt-2 text-sm leading-6 text-red-800"><%= note.body %></p>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

    <section class="space-y-3">
      <h2 class="text-xl font-black">Photos</h2>
      <% if service_visit.photos.attached? && show_photos %>
        <div class="grid gap-3 sm:grid-cols-2">
          <% service_visit.photos.each do |photo| %>
            <%= image_tag photo, alt: "", class: "aspect-[4/3] w-full rounded-md object-cover ring-1 ring-slate-200" %>
          <% end %>
        </div>
      <% elsif service_visit.photos.attached? %>
        <p class="leading-7 text-slate-700">Photos are attached to this visit and available in Boat Binder.</p>
      <% else %>
        <p class="leading-7 text-slate-700">No photos uploaded for this visit.</p>
      <% end %>
    </section>
  </div>
</article>
