<section class="space-y-5">
  <div class="flex items-start justify-between gap-4">
    <div>
      <%= link_to "Back to #{@vessel.name}", vessel_path(@vessel), class: "inline-flex min-h-10 items-center rounded-md py-2 text-sm font-bold text-cyan-700" %>
      <h1 class="mt-3 text-3xl font-black tracking-normal">Service visits</h1>
    </div>
    <%= link_to "Start", new_vessel_service_visit_path(@vessel), class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-bold text-white" %>
  </div>

  <div class="space-y-3">
    <% @service_visits.each do |visit| %>
      <%= link_to vessel_service_visit_path(@vessel, visit), class: "block rounded-md border border-slate-200 bg-white p-4 shadow-sm" do %>
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-lg font-black"><%= short_date(visit.visit_date) %></p>
            <p class="mt-1 text-sm text-slate-600"><%= visit.summary.presence || "Visit report" %></p>
          </div>
          <% if visit.follow_up_needed? %>
            <%= status_chip("Follow-up", tone: :urgent) %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
