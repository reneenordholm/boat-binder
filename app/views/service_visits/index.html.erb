<section class="space-y-6">
  <div class="rounded-md bg-[#0B1F35] p-5 text-white shadow-sm md:p-6">
    <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
      <div>
        <% if @vessel %>
          <%= link_to "Back to #{@vessel.name}", vessel_path(@vessel), class: "inline-flex min-h-10 items-center rounded-md py-2 text-sm font-black text-[#B9D5DA] hover:text-white" %>
          <p class="mt-3 text-sm font-black uppercase tracking-normal text-[#7DAAB3]"><%= @vessel.account.name %></p>
        <% else %>
          <p class="text-sm font-black uppercase tracking-normal text-[#7DAAB3]">Operations</p>
        <% end %>
        <h1 class="mt-1 text-3xl font-black tracking-normal">Service visits</h1>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-200">
          <% if @vessel %>
            A vessel-level history of captain visits, inspection notes, engine readings, and follow-up items.
          <% else %>
            A reverse-chronological service history across the vessels visible to your account.
          <% end %>
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        <% if @vessel && can_manage_records? %>
          <%= link_to "Add Service Visit", new_vessel_service_visit_path(@vessel), class: primary_button_class("bg-[#7DAAB3] text-[#0B1F35] hover:bg-[#B9D5DA]") %>
        <% end %>
      </div>
    </div>

    <div class="mt-6 grid gap-3 sm:grid-cols-3">
      <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
        <p class="text-xs font-bold uppercase tracking-normal text-[#B9D5DA]">Reports</p>
        <p class="mt-2 text-2xl font-black"><%= @service_visits.size %></p>
      </div>
      <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
        <p class="text-xs font-bold uppercase tracking-normal text-[#B9D5DA]">Vessels</p>
        <p class="mt-2 text-2xl font-black"><%= @service_visits.map(&:asset_id).uniq.size %></p>
      </div>
      <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
        <p class="text-xs font-bold uppercase tracking-normal text-[#B9D5DA]">Follow-ups</p>
        <p class="mt-2 text-2xl font-black"><%= @service_visits.count(&:follow_up_needed?) %></p>
      </div>
    </div>
  </div>

  <% if @service_visits.any? %>
    <div class="grid gap-4 xl:grid-cols-2">
      <% @service_visits.each do |visit| %>
        <% vessel = visit.asset %>
        <article class="<%= app_card_class("p-5 transition hover:border-[#7DAAB3] hover:shadow-md") %>">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-sm font-black uppercase tracking-normal text-[#1E5A7A]"><%= short_date(visit.visit_date, account: vessel.account) %></p>
              <h2 class="mt-1 text-xl font-black tracking-normal"><%= vessel.name %></h2>
              <p class="mt-1 text-sm font-semibold text-slate-600"><%= vessel.account.name %></p>
            </div>
            <div class="flex flex-wrap gap-2">
              <%= status_chip(visit.follow_up_needed? ? "Follow-up needed" : "Report filed", tone: visit.follow_up_needed? ? :urgent : :success) %>
            </div>
          </div>

          <p class="mt-4 text-sm leading-6 text-slate-700"><%= visit.summary.presence || "No summary recorded for this visit." %></p>

          <dl class="mt-5 grid gap-3 border-t border-[#F0E8DE] pt-4 text-sm sm:grid-cols-2">
            <div>
              <dt class="font-semibold text-slate-500">Performed by</dt>
              <dd class="mt-1 font-black"><%= user_display_name(visit.performed_by_user) %></dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-500">Location</dt>
              <dd class="mt-1 font-black"><%= visit.location.presence || vessel.location_label %></dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-500">Engine hours</dt>
              <dd class="mt-1 font-black"><%= service_visit_engine_hour_summary(visit) %></dd>
            </div>
            <div>
              <dt class="font-semibold text-slate-500">Checklist</dt>
              <dd class="mt-1 font-black">
                <% if service_visit_total_check_count(visit).positive? %>
                  <%= service_visit_checked_count(visit) %> of <%= service_visit_total_check_count(visit) %> checked
                <% else %>
                  Not recorded
                <% end %>
              </dd>
            </div>
          </dl>

          <% if visit.follow_up_notes.present? %>
            <div class="mt-4 rounded-md border border-amber-100 bg-amber-50 p-4 text-sm text-amber-900">
              <p class="font-black">Follow-up</p>
              <p class="mt-1 leading-6"><%= visit.follow_up_notes %></p>
            </div>
          <% end %>

          <div class="mt-5 flex flex-wrap gap-2">
            <%= link_to "View visit details", vessel_service_visit_path(vessel, visit), class: primary_button_class("min-h-10") %>
            <%= link_to "View vessel", vessel_path(vessel), class: secondary_button_class("min-h-10") %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="<%= app_card_class("p-8 text-center") %>">
      <p class="text-lg font-black">No service visits recorded yet.</p>
      <p class="mx-auto mt-2 max-w-xl text-sm leading-6 text-slate-600">
        Completed service visits will appear here as owner-ready reports with summaries, inspection notes, engine readings, and follow-up recommendations.
      </p>
      <% if @vessel && can_manage_records? %>
        <%= link_to "Add Service Visit", new_vessel_service_visit_path(@vessel), class: primary_button_class("mt-5") %>
      <% end %>
    </div>
  <% end %>
</section>
