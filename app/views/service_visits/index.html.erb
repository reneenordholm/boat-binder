<section class="space-y-6">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <% if @vessel %>
        <%= link_to "Back to #{@vessel.name}", vessel_path(@vessel), class: subtle_link_class("-ml-3") %>
        <p class="mt-3 text-sm font-black uppercase tracking-normal text-[#1E5A7A]"><%= @vessel.name %></p>
      <% else %>
        <p class="text-sm font-black uppercase tracking-normal text-[#1E5A7A]">Operations</p>
      <% end %>
      <h1 class="mt-1 text-3xl font-black tracking-normal">Service visits</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">
        <% if @vessel %>
          Recent service activity and visit reports for this vessel.
        <% else %>
          Recent service activity across the vessels visible to your account.
        <% end %>
      </p>
    </div>
    <% if @vessel && can_manage_records? %>
      <%= link_to "Start Visit", new_vessel_service_visit_path(@vessel), class: primary_button_class %>
    <% end %>
  </div>

  <% if @service_visits.any? %>
    <div class="grid gap-4 lg:grid-cols-2">
    <% @service_visits.each do |visit| %>
      <%= link_to vessel_service_visit_path(visit.asset, visit), class: app_card_class("block p-5 transition hover:-translate-y-0.5 hover:border-[#7DAAB3] hover:shadow-md") do %>
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-lg font-black"><%= visit.asset.name %></p>
            <p class="mt-1 text-sm font-semibold text-[#1E5A7A]"><%= short_date(visit.visit_date) %></p>
            <p class="mt-2 text-sm text-slate-600"><%= visit.summary.presence || "Visit report" %></p>
          </div>
          <% if visit.follow_up_needed? %>
            <%= status_chip("Follow-up", tone: :urgent) %>
          <% end %>
        </div>
        <div class="mt-5 grid gap-3 border-t border-[#F0E8DE] pt-4 text-sm sm:grid-cols-2">
          <div>
            <p class="font-semibold text-slate-500">Owner</p>
            <p class="mt-1 font-black"><%= visit.asset.account.name %></p>
          </div>
          <div>
            <p class="font-semibold text-slate-500">Performed by</p>
            <p class="mt-1 font-black"><%= visit.performed_by_user.email %></p>
          </div>
        </div>
      <% end %>
    <% end %>
    </div>
  <% else %>
    <div class="<%= app_card_class("p-6") %>">
      <p class="text-lg font-black">No service visits recorded yet.</p>
      <p class="mt-2 text-sm leading-6 text-slate-600">Completed service visits will appear here for review.</p>
      <% if @vessel && can_manage_records? %>
        <%= link_to "Start Visit", new_vessel_service_visit_path(@vessel), class: primary_button_class("mt-4") %>
      <% end %>
    </div>
  <% end %>
</section>
