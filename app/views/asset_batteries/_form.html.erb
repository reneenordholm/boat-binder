<%= field_error_messages(@battery) %>

<%= form_with model: [@vessel, @battery], url: @battery.persisted? ? vessel_battery_path(@vessel, @battery) : vessel_batteries_path(@vessel), class: "space-y-5" do |form| %>
  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
    <div>
      <%= form.label :name, "Battery name", class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_field :name, placeholder: "House Battery 1", class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div>
      <%= form.label :location, class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_field :location, placeholder: "Aft lazarette, engine room, bow compartment", class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div>
      <%= form.label :battery_type, "Battery type", class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_field :battery_type, placeholder: "AGM, lithium, flooded, gel", class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <label class="flex min-h-12 items-center gap-3 rounded-md border border-slate-300 px-4 py-3">
      <%= form.check_box :active, class: "h-5 w-5 rounded border-slate-300 text-cyan-700" %>
      <span class="text-sm font-bold text-slate-700">Active battery</span>
    </label>
    <div>
      <%= form.label :notes, class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_area :notes, rows: 4, placeholder: "Replacement date, charging notes, access details.", class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
  </section>

  <%= form.submit @battery.persisted? ? "Save battery" : "Add battery", class: "min-h-14 w-full rounded-md bg-cyan-700 px-5 py-4 text-base font-black text-white shadow-sm" %>
<% end %>
