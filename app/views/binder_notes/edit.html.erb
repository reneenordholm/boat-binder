<section class="mx-auto max-w-2xl space-y-5">
  <div>
    <%= link_to "Back to #{@vessel.name}", vessel_path(@vessel, anchor: "notes"), class: "inline-flex min-h-10 items-center rounded-md py-2 text-sm font-bold text-cyan-700" %>
    <p class="mt-3 text-sm font-bold uppercase tracking-normal text-cyan-700">Binder notes</p>
    <h1 class="mt-1 text-3xl font-black tracking-normal">Edit note</h1>
  </div>

  <%= field_error_messages(@binder_note) %>

  <%= form_with model: @binder_note, url: vessel_binder_note_path(@vessel, @binder_note), class: "space-y-5" do |form| %>
    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <div>
        <%= form.label :title, class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_field :title, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :note_type, "Type", class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :note_type, BinderNote::NOTE_TYPES.map { |type| [type.humanize, type] }, {}, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :due_date, class: "text-sm font-semibold text-slate-700" %>
        <%= form.date_field :due_date, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :body, class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_area :body, rows: 5, class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    </section>

    <%= form.submit "Save note", class: "min-h-14 w-full rounded-md bg-cyan-700 px-5 py-4 text-base font-black text-white shadow-sm" %>
  <% end %>
</section>
