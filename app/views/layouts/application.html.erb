<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Boat Binder" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Boat Binder">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <%= favicon_link_tag "favicon.svg", type: "image/svg+xml" %>
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#F7F5F2] text-[#0B1F35] antialiased">
    <div class="min-h-screen pb-24 md:pb-0">
      <% if authenticated? %>
        <aside class="fixed inset-y-0 left-0 z-40 hidden w-72 flex-col bg-[#0B1F35] text-white md:flex">
          <div class="p-6">
            <%= link_to root_path, class: "flex items-center gap-3" do %>
              <%= render "shared/brand_mark", class_name: "h-12 w-12" %>
              <span>
                <span class="block text-xl font-black leading-tight tracking-normal">Boat Binder</span>
                <span class="block text-xs font-bold uppercase tracking-normal text-[#B9D5DA]">Hayes Yacht Company</span>
              </span>
            <% end %>
          </div>

          <nav class="flex-1 space-y-1 px-4">
            <% app_nav_items.each do |label, path, initial| %>
              <%= link_to path, class: "group flex min-h-11 items-center gap-3 rounded-md px-3 py-2 text-sm font-bold text-[#D6E8EB] transition hover:bg-white/10 hover:text-white" do %>
                <span class="grid h-8 w-8 place-items-center rounded-md bg-white/10 text-xs text-[#B9D5DA] group-hover:bg-[#7DAAB3] group-hover:text-[#0B1F35]" aria-hidden="true">
                  <span class="h-2 w-2 rounded-full bg-[#7DAAB3] group-hover:bg-[#0B1F35]"></span>
                </span>
                <span><%= label %></span>
              <% end %>
            <% end %>
          </nav>

          <div class="m-4 rounded-md bg-white/10 p-4 ring-1 ring-white/10">
            <p class="truncate text-sm font-black"><%= user_display_name(Current.user) %></p>
            <span class="mt-2 inline-flex rounded-full bg-[#E8F3F5] px-2.5 py-1 text-xs font-black text-[#0B1F35]"><%= role_label(Current.user) %></span>
            <%= button_to "Sign out", session_path, method: :delete, class: "mt-4 min-h-10 w-full rounded-md bg-white px-3 py-2 text-sm font-black text-[#0B1F35] transition hover:bg-[#F7F5F2]" %>
          </div>
        </aside>

        <header class="sticky top-0 z-30 border-b border-[#E7DED2] bg-white/95 backdrop-blur md:hidden">
          <div class="flex items-center justify-between px-4 py-3">
            <%= link_to root_path, class: "flex items-center gap-2" do %>
              <%= render "shared/brand_mark", class_name: "h-10 w-10" %>
              <span>
                <span class="block text-base font-black leading-tight">Boat Binder</span>
                <span class="block text-xs font-medium text-[#1E5A7A]">Hayes Yacht Company</span>
              </span>
            <% end %>
            <div class="text-right">
              <p class="max-w-32 truncate text-xs font-black"><%= user_display_name(Current.user) %></p>
              <span class="mt-1 inline-flex rounded-full bg-[#E8F3F5] px-2 py-0.5 text-[0.7rem] font-black text-[#1E5A7A]"><%= role_label(Current.user) %></span>
            </div>
          </div>
        </header>
      <% end %>

      <div class="<%= authenticated? ? "md:ml-72" : "" %>">
        <% if notice || alert %>
          <div class="mx-auto max-w-7xl px-4 pt-4 md:px-8">
            <% if notice %>
              <div class="rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-bold text-emerald-800"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-700"><%= alert %></div>
            <% end %>
          </div>
        <% end %>

        <main class="mx-auto max-w-7xl px-4 py-5 md:px-8 md:py-8">
          <%= yield %>
        </main>
      </div>

      <% if authenticated? %>
        <nav class="fixed inset-x-0 bottom-0 z-40 border-t border-[#E7DED2] bg-white md:hidden">
          <div class="grid auto-cols-fr grid-flow-col text-center text-[0.7rem] font-black text-[#0B1F35]">
            <% app_nav_items.first(5).each do |label, path, initial| %>
              <%= link_to path, class: "py-3" do %>
                <span class="mx-auto mb-1 grid h-7 w-7 place-items-center rounded-md bg-[#E8F3F5] text-xs text-[#1E5A7A]" aria-hidden="true">
                  <span class="h-2 w-2 rounded-full bg-[#1E5A7A]"></span>
                </span>
                <%= { "Dashboard" => "Home", "Owners" => "Clients", "Documents" => "Docs", "Service Visits" => "Visits" }.fetch(label, label) %>
              <% end %>
            <% end %>
          </div>
        </nav>
      <% end %>
    </div>
  </body>
</html>
