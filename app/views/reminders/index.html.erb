<section class="space-y-5">
  <div>
    <p class="text-sm font-bold uppercase tracking-normal text-cyan-700">Work queue</p>
    <h1 class="mt-1 text-3xl font-black tracking-normal">Reminders</h1>
  </div>

  <div class="space-y-3">
    <% @reminders.each do |reminder| %>
      <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-lg font-black"><%= reminder.title %></p>
            <p class="mt-1 text-sm text-slate-600"><%= reminder.asset.name %> - <%= reminder.asset.account.name %></p>
            <p class="mt-1 text-sm font-semibold text-slate-500"><%= reminder.reminder_type.humanize %> due <%= short_date(reminder.due_date) %></p>
          </div>
          <%= status_chip(reminder.status.humanize, tone: reminder.status == "completed" ? :success : :warning) %>
        </div>
        <% if reminder.status == "pending" %>
          <%= button_to "Mark complete", reminder_path(reminder), method: :patch, class: "mt-4 min-h-12 w-full rounded-md bg-emerald-700 px-4 py-3 text-base font-bold text-white" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
