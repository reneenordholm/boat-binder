<%= field_error_messages(reminder) %>

<%= form_with model: reminder, class: "space-y-5" do |form| %>
  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-black">Reminder</h2>
    <div>
      <%= form.label :asset_id, "Owner / vessel", class: "text-sm font-semibold text-slate-700" %>
      <%= form.grouped_collection_select :asset_id, accounts, :vessel_assets, :name, :id, :name, { prompt: "Select owner and vessel" }, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div>
      <%= form.label :title, class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_field :title, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= form.label :reminder_type, "Type", class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :reminder_type, Reminder::REMINDER_TYPES.map { |type| [type.humanize, type] }, {}, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :due_date, class: "text-sm font-semibold text-slate-700" %>
        <%= form.date_field :due_date, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    </div>
    <% if reminder.persisted? %>
      <div>
        <%= form.label :status, class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :status, Reminder::STATUSES.map { |status| [status.humanize, status] }, {}, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    <% end %>
  </section>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
    <%= form.submit reminder.persisted? ? "Save reminder" : "Add reminder", class: "min-h-12 rounded-md bg-cyan-700 px-5 py-3 text-base font-black text-white shadow-sm", data: { turbo_submits_with: "Saving..." } %>
    <%= link_to "Cancel", reminders_path, class: "inline-flex min-h-12 items-center justify-center rounded-md px-5 py-3 text-base font-bold text-slate-700" %>
  </div>
<% end %>
