<section class="space-y-6">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-normal text-cyan-700"><%= Date.current.strftime("%A, %b %-d") %></p>
      <h1 class="mt-1 text-3xl font-black tracking-normal md:text-4xl">Captain dashboard</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">Your live view of vessels, due items, recent visits, and reports ready for owner follow-up.</p>
    </div>
    <%= link_to "View vessels", vessels_path, class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-bold text-white shadow-sm" %>
  </div>

  <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
    <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-sm font-semibold text-slate-500">Vessels</p>
      <p class="mt-2 text-3xl font-black"><%= @vessels.size %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-sm font-semibold text-slate-500">Due tasks</p>
      <p class="mt-2 text-3xl font-black"><%= @upcoming_reminders.size %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-sm font-semibold text-slate-500">Recent visits</p>
      <p class="mt-2 text-3xl font-black"><%= @recent_service_visits.size %></p>
    </div>
    <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <p class="text-sm font-semibold text-slate-500">Follow-ups</p>
      <p class="mt-2 text-3xl font-black"><%= @follow_up_items.size %></p>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
    <section class="space-y-3">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-black">Today's vessel list</h2>
        <%= link_to "All", vessels_path, class: "rounded-md px-3 py-2 text-sm font-bold text-cyan-700" %>
      </div>
      <div class="space-y-3">
        <% @vessels.each do |vessel| %>
          <%= link_to vessel_path(vessel), class: "block rounded-md border border-slate-200 bg-white p-4 shadow-sm" do %>
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-black"><%= vessel.name %></h3>
                <p class="mt-1 text-sm text-slate-600"><%= vessel.account.name %> - <%= [vessel.marina, vessel.slip.presence && "Slip #{vessel.slip}"].compact.join(" - ") %></p>
              </div>
              <% if reminder = vessel.next_reminder %>
                <%= status_chip(short_date(reminder.due_date), tone: reminder.due_date <= Date.current + 7.days ? :urgent : :warning) %>
              <% end %>
            </div>
            <p class="mt-3 text-sm font-medium text-slate-500">Last visit: <%= short_date(vessel.last_visit&.visit_date) %></p>
          <% end %>
        <% end %>
      </div>
    </section>

    <aside class="space-y-5">
      <section>
        <h2 class="mb-3 text-xl font-black">Upcoming reminders</h2>
        <div class="space-y-3">
          <% @upcoming_reminders.each do |reminder| %>
            <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="font-bold"><%= reminder.title %></p>
                  <p class="mt-1 text-sm text-slate-600"><%= reminder.asset.name %></p>
                </div>
                <%= status_chip(short_date(reminder.due_date), tone: reminder.due_date <= Date.current ? :urgent : :warning) %>
              </div>
            </div>
          <% end %>
        </div>
      </section>

      <section>
        <h2 class="mb-3 text-xl font-black">Recent reports</h2>
        <div class="space-y-3">
          <% @recent_service_visits.each do |visit| %>
            <%= link_to vessel_service_visit_path(visit.asset, visit), class: "block rounded-md border border-slate-200 bg-white p-4 shadow-sm" do %>
              <p class="font-bold"><%= visit.asset.name %></p>
              <p class="mt-1 text-sm text-slate-600"><%= short_date(visit.visit_date) %> by <%= visit.performed_by_user.email %></p>
            <% end %>
          <% end %>
        </div>
      </section>
    </aside>
  </div>
</section>
