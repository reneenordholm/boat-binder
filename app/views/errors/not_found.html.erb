<% content_for :title, "Page not found | Boat Binder" %>

<section class="mx-auto flex min-h-[calc(100vh-10rem)] max-w-4xl items-center justify-center py-8">
  <article class="w-full overflow-hidden rounded-md border border-[#D9E7EA] bg-white shadow-sm">
    <div class="bg-[#0B1F35] px-6 py-8 text-white sm:px-8">
      <div class="flex items-center gap-3">
        <%= render "shared/brand_mark", class_name: "h-12 w-12" %>
        <div>
          <p class="text-sm font-black uppercase tracking-normal text-[#B9D5DA]">Boat Binder</p>
          <p class="text-xs font-bold uppercase tracking-normal text-[#7DAAB3]">Hayes Yacht Company</p>
        </div>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
        <div>
          <p class="text-sm font-black uppercase tracking-normal text-[#7DAAB3]">404</p>
          <h1 class="mt-3 max-w-2xl text-4xl font-black tracking-normal sm:text-5xl"><%= @not_found_message %></h1>
        </div>
        <svg class="h-24 w-full text-[#7DAAB3] md:h-28 md:w-44" viewBox="0 0 220 120" role="img" aria-labelledby="not-found-waves-title">
          <title id="not-found-waves-title">Three calm nautical wave lines</title>
          <path d="M16 76c20-22 42-22 62 0s42 22 62 0 42-22 62 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="8" opacity="0.95" />
          <path d="M16 96c20-18 42-18 62 0s42 18 62 0 42-18 62 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="8" opacity="0.58" />
          <path d="M70 42l40-24 40 24-40 22-40-22Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="7" opacity="0.72" />
        </svg>
      </div>
    </div>

    <div class="space-y-6 px-6 py-6 sm:px-8">
      <p class="max-w-2xl text-base leading-7 text-slate-700">
        The page may have moved, been removed, or may not be available to your account. No private account, vessel, or route details are shown here.
      </p>

      <div class="flex flex-col gap-3 sm:flex-row">
        <% if authenticated? %>
          <%= link_to "Return to dashboard", root_path, class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-black text-white shadow-sm transition hover:bg-cyan-800" %>
        <% else %>
          <%= link_to "Return to sign in", new_session_path, class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-black text-white shadow-sm transition hover:bg-cyan-800" %>
        <% end %>
      </div>
    </div>
  </article>
</section>
