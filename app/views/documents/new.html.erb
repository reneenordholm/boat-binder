<section class="mx-auto max-w-2xl space-y-5">
  <div>
    <%= link_to "Back to #{@vessel.name}", vessel_path(@vessel, anchor: "documents"), class: "inline-flex min-h-10 items-center rounded-md py-2 text-sm font-bold text-cyan-700" %>
    <p class="mt-3 text-sm font-bold uppercase tracking-normal text-cyan-700">Upload</p>
    <h1 class="mt-1 text-3xl font-black tracking-normal">Add document</h1>
  </div>

  <%= field_error_messages(@document) %>

  <%= form_with model: @document, url: vessel_documents_path(@vessel), class: "space-y-5" do |form| %>
    <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
      <div>
        <%= form.label :title, class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_field :title, placeholder: "Insurance policy, registration, maintenance receipt", class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :document_type, class: "text-sm font-semibold text-slate-700" %>
        <%= form.select :document_type, Document::DOCUMENT_TYPES.map { |type| [type.humanize, type] }, {}, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
      <div>
        <%= form.label :file, class: "text-sm font-semibold text-slate-700" %>
        <%= form.file_field :file, accept: "image/*,.pdf,.doc,.docx", capture: "environment", class: "mt-2 block min-h-12 w-full rounded-md border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-base file:mr-3 file:rounded-md file:border-0 file:bg-cyan-700 file:px-4 file:py-2 file:font-bold file:text-white" %>
      </div>
      <div>
        <%= form.label :notes, class: "text-sm font-semibold text-slate-700" %>
        <%= form.text_area :notes, rows: 4, class: "mt-2 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
      </div>
    </section>

    <%= form.submit "Upload document", class: "min-h-14 w-full rounded-md bg-cyan-700 px-5 py-4 text-base font-black text-white shadow-sm" %>
  <% end %>
</section>
