<section class="mx-auto max-w-2xl space-y-5">
  <div>
    <%= link_to @vessel ? "Back to #{@vessel.name}" : "Back to documents", @vessel ? vessel_path(@vessel, anchor: "documents") : documents_path, class: "inline-flex min-h-10 items-center rounded-md py-2 text-sm font-bold text-cyan-700" %>
    <p class="mt-3 text-sm font-bold uppercase tracking-normal text-cyan-700">Upload</p>
    <h1 class="mt-1 text-3xl font-black tracking-normal">Add document</h1>
  </div>

  <%= render "form",
    document: @document,
    vessel: @vessel,
    accounts: @accounts,
    form_url: @vessel ? vessel_documents_path(@vessel) : documents_path,
    form_method: :post,
    submit_label: "Upload document",
    submitting_label: "Uploading..." %>
</section>
