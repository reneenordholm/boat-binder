<section class="space-y-5">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-normal text-cyan-700">Binder library</p>
      <h1 class="mt-1 text-3xl font-black tracking-normal">Documents</h1>
    </div>
    <%= link_to "New document", new_document_path, class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-bold text-white shadow-sm" %>
  </div>

  <div class="grid gap-3 md:grid-cols-2">
    <% @documents.each do |document| %>
      <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-lg font-black"><%= document.title %></p>
            <p class="mt-1 text-sm text-slate-600"><%= document.asset&.name || document.account.name %></p>
          </div>
          <%= status_chip(document.document_type.humanize, tone: :neutral) %>
        </div>
        <% if document.notes.present? %>
          <p class="mt-3 text-sm leading-6 text-slate-600"><%= document.notes %></p>
        <% end %>
        <% if document.file.attached? %>
          <div class="mt-4 flex flex-wrap gap-2">
            <%= link_to "Open file", url_for(document.file), class: "inline-flex min-h-11 items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-bold text-white" %>
            <%= link_to "Download", rails_blob_path(document.file, disposition: "attachment"), class: "inline-flex min-h-11 items-center rounded-md border border-slate-200 px-4 py-2 text-sm font-bold text-slate-700" %>
            <%= button_to "Delete", document_path(document), method: :delete, form: { data: { turbo_confirm: "Delete #{document.title}?" } }, class: "min-h-11 rounded-md border border-red-200 px-4 py-2 text-sm font-bold text-red-700" %>
          </div>
        <% else %>
          <div class="mt-4">
            <%= button_to "Delete", document_path(document), method: :delete, form: { data: { turbo_confirm: "Delete #{document.title}?" } }, class: "min-h-11 rounded-md border border-red-200 px-4 py-2 text-sm font-bold text-red-700" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
