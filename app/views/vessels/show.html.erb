<% can_manage_vessel = can_manage_account?(@vessel.account) %>

<section class="space-y-6">
  <div class="overflow-hidden rounded-md bg-[#0B1F35] text-white shadow-sm shadow-[#0B1F35]/15">
    <div class="p-6 md:p-8">
      <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
        <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between lg:block">
          <div>
            <p class="text-sm font-black uppercase tracking-normal text-[#B9D5DA]"><%= @vessel.account.name %></p>
            <h1 class="mt-2 text-4xl font-black tracking-normal md:text-5xl"><%= @vessel.name %></h1>
            <p class="mt-3 max-w-2xl text-base leading-7 text-[#D6E8EB]"><%= @vessel.display_model.presence || "Vessel profile" %></p>
          </div>
          <div class="mt-5 flex flex-wrap items-center gap-2 md:mt-0 md:justify-end lg:justify-start">
            <%= status_chip(@vessel.status_label, tone: @vessel.status_tone) %>
            <% if internal_user? %>
              <%= link_to "Start Visit", new_vessel_service_visit_path(@vessel), class: primary_button_class("min-h-12 bg-[#7DAAB3] px-5 py-3 text-base text-[#0B1F35] hover:bg-[#B9D5DA]") %>
            <% end %>
            <% if can_manage_vessel %>
              <%= link_to "Edit", edit_vessel_path(@vessel), class: secondary_button_class("min-h-12 border-white/20 bg-white/10 px-5 py-3 text-base text-white hover:bg-white/20 hover:text-white") %>
            <% end %>
          </div>
        </div>

        <div class="overflow-hidden rounded-md bg-white/10 ring-1 ring-white/10">
          <%= vessel_primary_photo(
            @vessel,
            image_class: "aspect-[16/10] w-full object-cover",
            placeholder_class: "flex aspect-[16/10] w-full flex-col items-center justify-center bg-[#12304D] p-5 text-center"
          ) %>
        </div>
      </div>

      <div class="mt-6 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
          <p class="text-slate-300">Location</p>
          <p class="mt-1 font-bold"><%= @vessel.location_label %></p>
        </div>
        <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
          <p class="text-slate-300">Owner</p>
          <p class="mt-1 font-bold"><%= @vessel.owner_name %></p>
          <% unless @vessel.account.active? %>
            <p class="mt-1 text-xs font-bold text-amber-200">Owner inactive</p>
          <% end %>
        </div>
        <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
          <p class="text-slate-300">Last visit</p>
          <p class="mt-1 font-bold"><%= short_date(@last_visit&.visit_date, account: @vessel.account) %></p>
        </div>
        <div class="rounded-md bg-white/10 p-4 ring-1 ring-white/10">
          <p class="text-slate-300">Next due</p>
          <p class="mt-1 font-bold"><%= @next_reminder ? "#{@next_reminder.title} - #{short_date(@next_reminder.due_date, account: @vessel.account)}" : "No open tasks" %></p>
        </div>
      </div>
    </div>
  </div>

  <nav class="flex gap-2 overflow-x-auto pb-1 text-sm font-bold">
    <a href="#status" class="min-h-10 shrink-0 rounded-md bg-white px-4 py-2.5 text-[#0B1F35] shadow-sm ring-1 ring-[#E7DED2] transition hover:bg-[#E8F3F5]">Overview</a>
    <a href="#documents" class="min-h-10 shrink-0 rounded-md bg-white px-4 py-2.5 text-[#0B1F35] shadow-sm ring-1 ring-[#E7DED2] transition hover:bg-[#E8F3F5]">Documents</a>
    <a href="#notes" class="min-h-10 shrink-0 rounded-md bg-white px-4 py-2.5 text-[#0B1F35] shadow-sm ring-1 ring-[#E7DED2] transition hover:bg-[#E8F3F5]">Notes</a>
    <a href="#visits" class="min-h-10 shrink-0 rounded-md bg-white px-4 py-2.5 text-[#0B1F35] shadow-sm ring-1 ring-[#E7DED2] transition hover:bg-[#E8F3F5]">Service Visits</a>
    <a href="#profile" class="min-h-10 shrink-0 rounded-md bg-white px-4 py-2.5 text-[#0B1F35] shadow-sm ring-1 ring-[#E7DED2] transition hover:bg-[#E8F3F5]">Profile</a>
    <a href="#batteries" class="min-h-10 shrink-0 rounded-md bg-white px-4 py-2.5 text-[#0B1F35] shadow-sm ring-1 ring-[#E7DED2] transition hover:bg-[#E8F3F5]">Batteries</a>
  </nav>

  <% if internal_user? %>
    <div class="<%= app_card_class("p-4") %>">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-black text-slate-900">Vessel record</p>
          <p class="mt-1 text-sm text-slate-600">Edit vessel details as ownership, slip, or registration changes.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <%= status_chip(@vessel.active? ? "Active" : "Inactive", tone: @vessel.active? ? :success : :neutral) %>
          <%= button_to "Delete vessel", vessel_path(@vessel), method: :delete, form: { data: { turbo_confirm: "Delete #{@vessel.name}? This also removes its visits, reminders, notes, and documents." } }, class: "min-h-11 rounded-md border border-red-200 px-4 py-2 text-sm font-bold text-red-700", data: { turbo_submits_with: "Deleting..." } %>
        </div>
      </div>
    </div>
  <% end %>

  <section id="status" class="grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="space-y-3">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-xl font-black">Priority board</h2>
        <%= link_to "All reminders", reminders_path, class: "rounded-md px-3 py-2 text-sm font-bold text-cyan-700" %>
      </div>

      <% if @open_follow_ups.any? || @overdue_reminders.any? %>
        <div class="space-y-3">
          <% @open_follow_ups.each do |visit| %>
            <%= link_to vessel_service_visit_path(@vessel, visit), class: "block rounded-md border border-red-200 bg-red-50 p-4 shadow-sm" do %>
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="font-black text-red-950">Follow-up from <%= short_date(visit.visit_date, account: @vessel.account) %></p>
                  <p class="mt-2 text-sm leading-6 text-red-800"><%= visit.follow_up_notes.presence || "Follow-up was marked during this visit." %></p>
                </div>
                <%= status_chip("Open", tone: :urgent) %>
              </div>
            <% end %>
          <% end %>

          <% @overdue_reminders.each do |reminder| %>
            <div class="flex items-center justify-between gap-3 rounded-md border border-red-200 bg-white p-4 shadow-sm">
              <div>
                <p class="font-black"><%= reminder.title %></p>
                <p class="mt-1 text-sm text-slate-600"><%= reminder.reminder_type.humanize %> due <%= short_date(reminder.due_date, account: @vessel.account) %></p>
              </div>
              <% if can_manage_vessel %>
                <%= button_to "Done", reminder_path(reminder, status_action: "complete"), method: :patch, class: "min-h-11 rounded-md bg-emerald-700 px-4 py-2 text-sm font-bold text-white", data: { turbo_submits_with: "Saving..." } %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-md border border-emerald-200 bg-emerald-50 p-4 shadow-sm">
          <p class="font-black text-emerald-900">No urgent vessel work</p>
          <p class="mt-2 text-sm leading-6 text-emerald-800">There are no overdue reminders or open visit follow-ups for this vessel.</p>
        </div>
      <% end %>
    </div>

    <div class="space-y-3">
      <h2 class="text-xl font-black">Upcoming work</h2>
      <div class="space-y-3">
        <% @upcoming_reminders.each do |reminder| %>
          <div class="flex items-center justify-between gap-3 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
            <div>
              <p class="font-bold"><%= reminder.title %></p>
              <p class="mt-1 text-sm text-slate-600"><%= reminder.reminder_type.humanize %> - <%= short_date(reminder.due_date, account: @vessel.account) %></p>
            </div>
            <%= status_chip(reminder.due_date <= account_today(@vessel.account) + 7.days ? "Soon" : "Queued", tone: reminder.due_date <= account_today(@vessel.account) + 7.days ? :warning : :neutral) %>
          </div>
        <% end %>
        <% if @upcoming_reminders.empty? %>
          <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
            <p class="font-bold">Nothing scheduled</p>
            <p class="mt-1 text-sm text-slate-600">Add the next maintenance, registration, insurance, or inspection reminder when ready.</p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <section id="profile" class="grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
    <div class="rounded-md border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-xl font-black">Owner contact</h2>
      <p class="mt-3 text-lg font-black"><%= @primary_contact&.name || @vessel.account.name %></p>
      <div class="mt-3 space-y-2 text-sm text-slate-600">
        <p><span class="font-semibold text-slate-800">Role:</span> <%= @primary_contact&.role.presence || "Client" %></p>
        <p><span class="font-semibold text-slate-800">Email:</span> <%= @primary_contact&.email.presence || "Not set" %></p>
        <p><span class="font-semibold text-slate-800">Phone:</span> <%= @primary_contact&.phone.presence || "Not set" %></p>
      </div>
      <% account_vessels = @vessel.account.assets.vessels.ordered %>
      <% if account_vessels.size > 1 %>
        <div class="mt-5 border-t border-slate-200 pt-4">
          <p class="text-sm font-bold text-slate-700">Owner vessels</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <% account_vessels.each do |owned_vessel| %>
              <%= link_to owned_vessel.name, vessel_path(owned_vessel), class: "rounded-md bg-slate-100 px-3 py-2 text-sm font-bold text-slate-700" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="rounded-md border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-xl font-black">Vessel profile</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= @vessel.notes.presence || "No standing vessel notes yet." %></p>
        </div>
        <%= status_chip(@vessel.registration_number.present? ? "Registered" : "Needs reg.", tone: @vessel.registration_number.present? ? :success : :warning) %>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-500">Make</p>
          <p class="mt-1 font-black"><%= @vessel.make.presence || "Not set" %></p>
        </div>
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-500">Model</p>
          <p class="mt-1 font-black"><%= @vessel.model.presence || "Not set" %></p>
        </div>
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-500">Length</p>
          <p class="mt-1 font-black"><%= @vessel.length.present? ? "#{@vessel.length.to_i} ft" : "Not set" %></p>
        </div>
        <div class="rounded-md bg-slate-50 p-4">
          <p class="text-sm font-semibold text-slate-500">Registration</p>
          <p class="mt-1 font-black"><%= @vessel.registration_number.presence || "Not set" %></p>
        </div>
      </div>
    </div>
  </section>

  <section id="batteries" class="space-y-3">
    <div class="flex items-center justify-between gap-3">
      <div>
        <h2 class="text-xl font-black">Batteries</h2>
        <p class="mt-1 text-sm text-slate-600">Track the vessel batteries that should be checked during service visits.</p>
      </div>
      <% if internal_user? %>
        <%= link_to "Add battery", new_vessel_battery_path(@vessel), class: "shrink-0 rounded-md px-3 py-2 text-sm font-bold text-cyan-700" %>
      <% end %>
    </div>

    <% if @asset_batteries.any? %>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        <% @asset_batteries.each do |battery| %>
          <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-black"><%= battery.name %></p>
                <p class="mt-1 text-sm text-slate-600"><%= battery.location.presence || "Location not set" %></p>
              </div>
              <%= status_chip(battery.status_label, tone: battery.status_tone) %>
            </div>
            <div class="mt-3 space-y-1 text-sm text-slate-600">
              <p><span class="font-semibold text-slate-800">Type:</span> <%= battery.battery_type.presence || "Not set" %></p>
              <% if battery.notes.present? %>
                <p class="leading-6"><%= battery.notes %></p>
              <% end %>
            </div>
            <% if internal_user? %>
              <div class="mt-4 flex flex-wrap gap-2">
                <%= link_to "Edit", edit_vessel_battery_path(@vessel, battery), class: "inline-flex min-h-10 items-center rounded-md bg-slate-900 px-4 py-2 text-sm font-bold text-white" %>
                <%= button_to "Delete", vessel_battery_path(@vessel, battery), method: :delete, form: { data: { turbo_confirm: "Delete #{battery.name}?" } }, class: "min-h-10 rounded-md border border-red-200 px-4 py-2 text-sm font-bold text-red-700", data: { turbo_submits_with: "Deleting..." } %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
        <p class="font-bold">No batteries added yet</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">Add vessel batteries so each one appears in the service visit battery check section.</p>
      </div>
    <% end %>
  </section>

  <section id="visits" class="space-y-3">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-sm font-black uppercase tracking-normal text-[#1E5A7A]">Vessel history</p>
        <h2 class="mt-1 text-xl font-black">Recent service visits</h2>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "View all service visits", vessel_service_visits_path(@vessel), class: secondary_button_class("min-h-10") %>
        <% if internal_user? %>
          <%= link_to "Add service visit", new_vessel_service_visit_path(@vessel), class: primary_button_class("min-h-10") %>
        <% end %>
      </div>
    </div>
    <% if @service_visits.any? %>
      <div class="space-y-3">
        <% @service_visits.each do |visit| %>
          <article class="<%= app_card_class("p-4 transition hover:border-[#7DAAB3] hover:shadow-md") %>">
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#E8F3F5] text-sm font-black text-[#1E5A7A] ring-1 ring-[#C9DEE2]">
                  <%= short_month(visit.visit_date, account: @vessel.account) %>
                </div>
                <div class="mt-2 min-h-10 w-px flex-1 bg-[#E7DED2]"></div>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                  <div>
                    <p class="font-black"><%= short_date(visit.visit_date, account: @vessel.account) %></p>
                    <p class="mt-1 text-sm leading-6 text-slate-600"><%= visit.summary.presence || "Visit report recorded." %></p>
                    <p class="mt-2 text-xs font-semibold text-slate-500">By <%= user_display_name(visit.performed_by_user) %></p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <% if visit.follow_up_needed? %>
                      <%= status_chip("Follow-up", tone: :urgent) %>
                    <% else %>
                      <%= status_chip("Filed", tone: :success) %>
                    <% end %>
                  </div>
                </div>
                <div class="mt-4 grid gap-2 text-sm sm:grid-cols-3">
                  <div class="rounded-md bg-[#F7F5F2] p-3">
                    <p class="font-semibold text-slate-500">Engine hours</p>
                    <p class="mt-1 font-black"><%= service_visit_engine_hour_summary(visit) %></p>
                  </div>
                  <div class="rounded-md bg-[#F7F5F2] p-3">
                    <p class="font-semibold text-slate-500">Checklist</p>
                    <p class="mt-1 font-black">
                      <% if service_visit_total_check_count(visit).positive? %>
                        <%= service_visit_checked_count(visit) %>/<%= service_visit_total_check_count(visit) %> checked
                      <% else %>
                        Not recorded
                      <% end %>
                    </p>
                  </div>
                  <div class="rounded-md bg-[#F7F5F2] p-3">
                    <p class="font-semibold text-slate-500">Battery checks</p>
                    <p class="mt-1 font-black"><%= service_visit_battery_check_count(visit) %></p>
                  </div>
                </div>
                <div class="mt-4">
                  <%= link_to "View visit details", vessel_service_visit_path(@vessel, visit), class: subtle_link_class("-ml-3") %>
                </div>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="<%= app_card_class("p-6") %>">
        <p class="text-lg font-black">No service visits recorded yet.</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Completed service visits and owner-ready reports will appear here.</p>
        <% if internal_user? %>
          <%= link_to "Add Service Visit", new_vessel_service_visit_path(@vessel), class: primary_button_class("mt-4") %>
        <% end %>
      </div>
    <% end %>
  </section>

  <section id="documents" class="space-y-3">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-xl font-black">Documents</h2>
      <% if can_manage_vessel %>
        <%= link_to "Upload", new_vessel_document_path(@vessel), class: subtle_link_class %>
      <% end %>
    </div>
    <% if @documents.any? %>
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        <% @documents.each do |document| %>
          <div class="<%= app_card_class("p-4") %>">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-bold"><%= link_to document.title, document_path(document), class: "transition hover:text-cyan-700" %></p>
                <p class="mt-1 text-sm capitalize text-slate-600"><%= document.document_type.humanize %></p>
              </div>
              <%= status_chip(document.file.attached? ? "Filed" : "Missing", tone: document.file.attached? ? :success : :warning) %>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              <%= link_to "View", document_path(document), class: secondary_button_class("min-h-10") %>
              <% if can_manage_vessel %>
                <%= link_to document.file.attached? ? "Edit" : "Edit / Add file", edit_document_path(document), class: secondary_button_class("min-h-10") %>
              <% end %>
              <% if document.file.attached? %>
                <%= link_to "Open file", url_for(document.file), class: primary_button_class("min-h-10") %>
                <%= link_to "Download", rails_blob_path(document.file, disposition: "attachment"), class: secondary_button_class("min-h-10") %>
              <% else %>
                <span class="inline-flex min-h-10 items-center rounded-md border border-dashed border-slate-300 px-4 py-2 text-sm font-bold text-slate-500">No file attached</span>
              <% end %>
              <% if can_manage_vessel %>
                <%= button_to "Delete", vessel_document_path(@vessel, document), method: :delete, form: { data: { turbo_confirm: "Delete #{document.title}?" } }, class: "min-h-10 rounded-md border border-red-200 px-4 py-2 text-sm font-bold text-red-700", data: { turbo_submits_with: "Deleting..." } %>
              <% end %>
            </div>
            <% if document.file.attached? %>
              <p class="mt-3 text-xs font-semibold text-[#1E5A7A]"><%= document.file.filename %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="<%= app_card_class("p-6") %>">
        <p class="text-lg font-black">No documents uploaded yet.</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Registration, insurance, contracts, receipts, and photos will appear here.</p>
        <% if can_manage_vessel %>
          <%= link_to "Upload Document", new_vessel_document_path(@vessel), class: primary_button_class("mt-4") %>
        <% end %>
      </div>
    <% end %>
  </section>

  <section id="notes" class="grid gap-5 <%= "lg:grid-cols-[0.8fr_1.2fr]" if can_manage_vessel %>">
    <% if can_manage_vessel %>
      <div>
      <h2 class="text-xl font-black">Add note</h2>
      <%= form_with model: @binder_note, url: vessel_binder_notes_path(@vessel), class: app_card_class("mt-3 p-4") do |form| %>
        <div class="space-y-3">
          <%= form.text_field :title, placeholder: "Note title", class: "min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
          <%= form.select :note_type, BinderNote::NOTE_TYPES.map { |type| [type.humanize, type] }, {}, class: "min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
          <div>
            <%= form.label :due_date, "Due date", class: "text-sm font-semibold text-slate-700" %>
            <%= form.date_field :due_date, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
          </div>
          <%= form.text_area :body, rows: 4, placeholder: "Owner preference, maintenance note, operational detail, or issue.", class: "w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
          <%= form.submit "Add note", class: "min-h-12 w-full rounded-md bg-[#0B1F35] px-4 py-3 font-bold text-white", data: { turbo_submits_with: "Adding..." } %>
        </div>
      <% end %>
      </div>
    <% end %>

    <div class="space-y-3">
      <h2 class="text-xl font-black">Binder notes</h2>
      <% if @binder_notes.any? %>
        <% @binder_notes.each do |note| %>
        <div class="rounded-md border <%= note.attention_due? ? "border-amber-200 bg-amber-50" : "border-slate-200 bg-white" %> p-4 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-bold"><%= note.title %></p>
              <% if note.due_date.present? %>
                <p class="mt-1 text-sm font-semibold text-amber-800">Due <%= short_date(note.due_date, account: @vessel.account) %></p>
              <% end %>
            </div>
            <div class="flex flex-col items-end gap-2">
              <%= status_chip(note.note_type.humanize, tone: note.note_type == "issue" ? :urgent : (note.attention_due? ? :warning : :neutral)) %>
              <% if can_manage_vessel %>
                <div class="flex gap-2">
                  <%= link_to "Edit", edit_vessel_binder_note_path(@vessel, note), class: "rounded-md px-2 py-1 text-xs font-bold text-cyan-700" %>
                  <%= button_to "Delete", vessel_binder_note_path(@vessel, note), method: :delete, form: { data: { turbo_confirm: "Delete this note?" } }, class: "rounded-md px-2 py-1 text-xs font-bold text-red-700", data: { turbo_submits_with: "Deleting..." } %>
                </div>
              <% end %>
            </div>
          </div>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= note.body %></p>
        </div>
        <% end %>
      <% else %>
        <div class="<%= app_card_class("p-6") %>">
          <p class="text-lg font-black">No open notes.</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Owner preferences, operational notes, and maintenance issues will appear here.</p>
        </div>
      <% end %>
    </div>
  </section>

  <% if internal_user? %>
    <div class="fixed inset-x-0 bottom-16 z-30 px-4 md:hidden">
      <%= link_to "Log Visit", new_vessel_service_visit_path(@vessel), class: "mx-auto flex min-h-14 max-w-6xl items-center justify-center rounded-md bg-cyan-700 px-5 py-4 text-base font-black text-white shadow-lg md:inline-flex md:min-h-12 md:shadow-sm" %>
    </div>
  <% end %>
</section>
