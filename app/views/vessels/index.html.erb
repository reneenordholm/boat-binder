<section class="space-y-5">
  <div>
    <p class="text-sm font-bold uppercase tracking-normal text-cyan-700">Fleet</p>
    <h1 class="mt-1 text-3xl font-black tracking-normal">Vessels</h1>
  </div>

  <div class="space-y-3">
    <% @vessels.each do |vessel| %>
      <%= link_to vessel_path(vessel), class: "block rounded-md border border-slate-200 bg-white p-4 shadow-sm" do %>
        <div class="flex items-start justify-between gap-3">
          <div>
            <h2 class="text-xl font-black"><%= vessel.name %></h2>
            <p class="mt-1 text-sm font-semibold text-slate-600"><%= vessel.owner_name %></p>
            <p class="mt-1 text-sm text-slate-500"><%= [vessel.marina, vessel.slip.presence && "Slip #{vessel.slip}"].compact.join(" - ") %></p>
          </div>
          <% if vessel.next_reminder %>
            <%= status_chip(short_date(vessel.next_reminder.due_date), tone: :warning) %>
          <% end %>
        </div>
        <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
          <div>
            <p class="font-semibold text-slate-500">Upcoming</p>
            <p class="mt-1 font-bold"><%= vessel.next_reminder&.title || "Clear" %></p>
          </div>
          <div>
            <p class="font-semibold text-slate-500">Last visit</p>
            <p class="mt-1 font-bold"><%= short_date(vessel.last_visit&.visit_date) %></p>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
