<section class="space-y-6">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-black uppercase tracking-normal text-[#1E5A7A]">Fleet</p>
      <h1 class="mt-1 text-3xl font-black tracking-normal md:text-5xl">Vessels</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">A premium fleet view for owners, captains, locations, documents, and next service priorities.</p>
    </div>
    <% if can_manage_records? %>
      <%= link_to "Add Vessel", new_vessel_path, class: primary_button_class %>
    <% end %>
  </div>

  <%= form_with url: vessels_path, method: :get, class: app_card_class("p-4") do |form| %>
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
      <%= form.search_field :q, value: @query, placeholder: "Search vessel, owner, marina, or slip", class: "min-h-12 flex-1 rounded-md border border-[#D7E4E7] bg-white px-4 py-3 text-base text-[#0B1F35] outline-none transition placeholder:text-slate-400 focus:border-[#1E5A7A] focus:ring-2 focus:ring-[#7DAAB3]/30" %>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <label class="flex min-h-12 items-center gap-3 rounded-md border border-[#D7E4E7] bg-[#F7F5F2] px-4 py-3">
          <%= form.check_box :include_inactive, { checked: @include_inactive, class: "h-5 w-5 rounded border-slate-300 text-[#1E5A7A]" }, "1", nil %>
          <span class="text-sm font-black text-[#0B1F35]">Include inactive</span>
        </label>
        <%= form.submit "Search", class: primary_button_class("min-h-12 px-6"), data: { turbo_submits_with: "Searching..." } %>
      </div>
    </div>
  <% end %>

  <% if @vessels.any? %>
    <div class="grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
      <% @vessels.each do |vessel| %>
        <article class="<%= app_card_class("flex flex-col overflow-hidden transition hover:-translate-y-0.5 hover:border-[#7DAAB3] hover:shadow-md") %>">
          <%= vessel_primary_photo(
            vessel,
            image_class: "aspect-[16/9] w-full object-cover",
            placeholder_class: "flex aspect-[16/9] w-full flex-col items-center justify-center bg-[#0B1F35] p-5 text-center"
          ) %>
          <div class="flex flex-1 flex-col p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-black uppercase tracking-normal text-[#1E5A7A]"><%= vessel.owner_name %></p>
                <h2 class="mt-1 text-2xl font-black tracking-normal"><%= link_to vessel.name, vessel_path(vessel), class: "transition hover:text-[#1E5A7A]" %></h2>
                <p class="mt-2 text-sm font-semibold text-slate-600"><%= vessel.display_model.presence || "Vessel profile" %></p>
              </div>
              <%= status_chip(vessel.active? ? "Active" : "Inactive", tone: vessel.active? ? :success : :neutral) %>
            </div>

            <div class="mt-5 space-y-2 text-sm text-slate-600">
              <p><span class="font-black text-[#0B1F35]">Owner:</span> <%= vessel.account.name %></p>
              <p><span class="font-black text-[#0B1F35]">Location:</span> <%= vessel.location_label %></p>
            </div>

            <div class="mt-5 grid grid-cols-2 gap-3 border-y border-[#F0E8DE] py-4 text-sm">
              <div>
                <p class="font-semibold text-slate-500">Open notes</p>
                <p class="mt-1 text-2xl font-black"><%= vessel.binder_notes.size %></p>
              </div>
              <div>
                <p class="font-semibold text-slate-500">Documents</p>
                <p class="mt-1 text-2xl font-black"><%= vessel.documents.size %></p>
              </div>
            </div>

            <div class="mt-4 flex items-center justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-normal text-slate-500">Next item</p>
                <p class="mt-1 text-sm font-black"><%= vessel.next_reminder&.title || "Clear" %></p>
              </div>
              <%= link_to "View Vessel", vessel_path(vessel), class: secondary_button_class("shrink-0") %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="<%= app_card_class("p-8 text-center") %>">
      <p class="text-2xl font-black">No vessels found.</p>
      <p class="mx-auto mt-2 max-w-xl text-sm leading-6 text-slate-600">Try a different search, include inactive vessels, or add the first vessel for this owner account.</p>
      <% if can_manage_records? %>
        <%= link_to "Add Vessel", new_vessel_path, class: primary_button_class("mt-5") %>
      <% end %>
    </div>
  <% end %>
</section>
