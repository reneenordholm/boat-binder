<section class="space-y-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-bold uppercase tracking-normal text-cyan-700">Admin</p>
      <h1 class="mt-1 text-3xl font-black tracking-normal">Users</h1>
      <p class="mt-2 text-sm text-slate-600">Manage internal users and read-only owner access.</p>
    </div>
    <%= link_to "Add user", new_admin_user_path, class: "inline-flex min-h-12 items-center justify-center rounded-md bg-cyan-700 px-5 py-3 text-base font-bold text-white shadow-sm" %>
  </div>

  <div class="grid gap-3">
    <% @users.each do |user| %>
      <div class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="font-black"><%= user.name.presence || user.email_address %></p>
            <p class="mt-1 text-sm text-slate-600"><%= user.email_address %></p>
            <div class="mt-2 flex flex-wrap gap-2">
              <%= status_chip(user.role.humanize, tone: user.internal? ? :success : :neutral) %>
              <%= status_chip(user.active? ? "Active" : "Inactive", tone: user.active? ? :success : :warning) %>
            </div>
          </div>
          <%= link_to "Edit", edit_admin_user_path(user), class: "inline-flex min-h-10 items-center justify-center rounded-md bg-slate-900 px-4 py-2 text-sm font-bold text-white" %>
        </div>

        <% if user.account_memberships.any? %>
          <div class="mt-4 border-t border-slate-200 pt-3">
            <p class="text-sm font-bold text-slate-700">Account access</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <% user.account_memberships.each do |membership| %>
                <span class="rounded-md bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700"><%= membership.account.name %> <%= "(inactive)" unless membership.active? %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
