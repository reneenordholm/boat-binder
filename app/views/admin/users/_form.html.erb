<%= field_error_messages(@user) %>

<% active_checked = defined?(@active_checked) && !@active_checked.nil? ? @active_checked : @user.active? %>
<% invitation_password_disabled = !@user.persisted? && @send_invitation %>

<%= form_with model: [:admin, @user], class: "space-y-5", data: { controller: "role-access admin-user-form" } do |form| %>
  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-black">User details</h2>
    <% unless @user.persisted? %>
      <label class="flex min-h-12 items-start gap-3 rounded-md border border-cyan-100 bg-cyan-50 px-4 py-3">
        <%= hidden_field_tag "user[send_invitation]", "0" %>
        <%= check_box_tag "user[send_invitation]", "1", @send_invitation, class: "mt-1 h-5 w-5 rounded border-slate-300 text-cyan-700", data: { admin_user_form_target: "sendInvitation", action: "change->admin-user-form#refreshInvitationFields" } %>
        <span>
          <span class="block text-sm font-bold text-slate-900">Send invitation email</span>
          <span class="mt-1 block text-sm leading-6 text-slate-600">The user will set their own password from a secure link. Invited users are created inactive, the Active user checkbox is ignored while sending an invitation, and users become active after accepting.</span>
        </span>
      </label>
    <% end %>
    <div>
      <%= form.label :name, class: "text-sm font-semibold text-slate-700" %>
      <%= form.text_field :name, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div>
      <%= form.label :email_address, "Email", class: "text-sm font-semibold text-slate-700" %>
      <%= form.email_field :email_address, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base" %>
    </div>
    <div>
      <%= form.label :role, class: "text-sm font-semibold text-slate-700" %>
      <%= form.select :role, User::ROLES.map { |role| [role.humanize, role] }, {}, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base", data: { role_access_target: "role", action: "role-access#refresh" } %>
    </div>
    <label class="flex min-h-12 items-center gap-3 rounded-md border border-slate-300 px-4 py-3">
      <%= form.check_box :active, { checked: active_checked, class: "h-5 w-5 rounded border-slate-300 text-cyan-700" }, "1", "0" %>
      <span class="text-sm font-bold text-slate-700">Active user</span>
    </label>
  </section>

  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm" data-admin-user-form-target="passwordSection">
    <h2 class="text-lg font-black">Password</h2>
    <% if @user.persisted? %>
      <p class="text-sm leading-6 text-slate-600">Leave password fields blank to keep the current password.</p>
    <% else %>
      <p class="text-sm leading-6 text-slate-600 <%= invitation_password_disabled ? nil : "hidden" %>" data-admin-user-form-target="invitationPasswordHelp">Invited users set their own password from the secure invitation link, so manual password fields are disabled while Send invitation email is checked.</p>
      <p class="text-sm leading-6 text-slate-600 <%= invitation_password_disabled ? "hidden" : nil %>" data-admin-user-form-target="manualPasswordHelp">Enter a password only when creating a manual user without an invitation email.</p>
    <% end %>
    <div>
      <%= form.label :password, class: "text-sm font-semibold text-slate-700" %>
      <%= form.password_field :password, autocomplete: "new-password", disabled: invitation_password_disabled, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-500", data: { admin_user_form_target: "passwordField" } %>
    </div>
    <div>
      <%= form.label :password_confirmation, class: "text-sm font-semibold text-slate-700" %>
      <%= form.password_field :password_confirmation, autocomplete: "new-password", disabled: invitation_password_disabled, class: "mt-2 min-h-12 w-full rounded-md border border-slate-300 px-4 py-3 text-base disabled:cursor-not-allowed disabled:bg-slate-100 disabled:text-slate-500", data: { admin_user_form_target: "passwordField" } %>
    </div>
  </section>

  <section class="space-y-4 rounded-md border border-slate-200 bg-white p-4 shadow-sm">
    <h2 class="text-lg font-black">Owner account access</h2>
    <p class="text-sm leading-6 text-slate-600" data-role-access-target="ownerHelp">Owner users can view records for selected accounts. Owner access is read-only.</p>
    <p class="hidden text-sm leading-6 text-slate-600" data-role-access-target="internalHelp">Admin and captain users have access to all vessels automatically.</p>
    <div class="grid gap-2 sm:grid-cols-2">
      <% active_account_ids = @user.account_memberships.active.pluck(:account_id) %>
      <% @accounts.each do |account| %>
        <% owner_checked = active_account_ids.include?(account.id) %>
        <% checked = @user.internal? || owner_checked %>
        <% disabled = @user.internal? %>
        <label class="flex min-h-12 items-center gap-3 rounded-md border px-4 py-3 <%= disabled ? "border-slate-200 bg-slate-50 text-slate-500" : "border-slate-300" %>" data-role-access-target="accessLabel">
          <%= check_box_tag "user[account_ids][]", account.id, checked, class: "h-5 w-5 rounded border-slate-300 text-cyan-700 disabled:text-slate-300", disabled: disabled, data: { role_access_target: "account", owner_checked: owner_checked } %>
          <span class="text-sm font-bold text-slate-700"><%= account.name %></span>
        </label>
      <% end %>
    </div>
  </section>

  <%= form.submit @user.persisted? ? "Save user" : "Add user", class: "min-h-14 w-full rounded-md bg-cyan-700 px-5 py-4 text-base font-black text-white shadow-sm", data: { turbo_submits_with: "Saving..." } %>
<% end %>
